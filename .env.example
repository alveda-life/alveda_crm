# Copy to .env and fill in real values. Never commit .env.

# Django
SECRET_KEY=replace-with-a-long-random-50+-char-string
DEBUG=False
USE_TLS=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Production example: https://crm.ask-ayurveda.com (scheme required; include port if non-443/80)
CSRF_TRUSTED_ORIGINS=
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

# Backend container: optional (default off on production)
CREATE_DEMO_USERS=false
# GUNICORN_WORKERS=3

# Postgres
POSTGRES_DB=ayurveda_crm
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Partners CRM import (management/commands/import_crm_contacts.py)
PARTNERS_CRM_API_KEY=your-crm-api-key
PARTNERS_CRM_API_BASE=https://example.com/api
